{
  "manifest_version": 3,
  "name": "DHL Label Creator (Team)",
  "version": "1.0.0",
  "description": "Erstellt DHL Versandlabels für eBay-Sendungen direkt im Browser. Team-Version ohne lokales Backend.",
  "permissions": ["storage", "unlimitedStorage", "sidePanel"],
  "host_permissions": [
    "https://api-eu.dhl.com/*",
    "https://api-sandbox.dhl.com/*",
    "https://discord.com/api/webhooks/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "DHL Label Creator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
